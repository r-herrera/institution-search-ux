# Port to run the app on (default: 3000)
PORT=3000

# Public base URL for API calls (set to your EC2/domain URL in production)
API_BASE_URL=http://localhost:3000/api

# Path to institutions JSON data file (default: data/institutions.json)
DATA_FILE_PATH=data/institutions.json

# --- School Registration (Address Autocomplete) ---

# Google Places API key (for autocomplete + place details)
NUXT_GOOGLE_PLACES_API_KEY=

# Google Address Validation API key
NUXT_GOOGLE_ADDRESS_VALIDATION_API_KEY=

# Apple Maps credentials
# NUXT_APPLE_MAPS_TEAM_ID: Your Apple Developer Team ID
NUXT_APPLE_MAPS_TEAM_ID=
# NUXT_APPLE_MAPS_KEY_ID: The key ID from your .p8 filename (e.g. P63R77N9Q4 from AuthKey_P63R77N9Q4.p8)
NUXT_APPLE_MAPS_KEY_ID=
# NUXT_APPLE_MAPS_PRIVATE_KEY: Entire .p8 file contents as a single line with newlines escaped as \n
# To encode: awk '{printf "%s\\n", $0}' AuthKey_XXXXXXXXXX.p8
# Do NOT commit or copy the .p8 file to the server — use this env var only.
NUXT_APPLE_MAPS_PRIVATE_KEY=

# Mapbox access token (server-side, keep secret)
NUXT_MAPBOX_ACCESS_TOKEN=
# Mapbox access token (client-side public, bundled into frontend)
NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Amazon Location Service
# API key created in the AWS Console (Amazon Location → API keys)
# See docs/amazon-location-setup.md for step-by-step instructions
NUXT_AMAZON_LOCATION_API_KEY=
# AWS region where the API key was created (e.g. us-east-1, eu-west-1)
NUXT_AMAZON_LOCATION_REGION=us-east-1
